# API Configuration
API_BEARER_TOKEN=constellation-dev-token

# Network Configuration
# HOST: Bind address for web server and API
#   - 0.0.0.0 = All interfaces (accessible from local network)
#   - 127.0.0.1 = Localhost only (local machine access only)
HOST=0.0.0.0

# PORT: Web UI and REST API port
PORT=8080

# Database Configuration
DB_PATH=./data/db/constellation.db

# NATS Configuration
# NATS_HOST: Bind address for NATS server
#   - 0.0.0.0 = All interfaces (accessible from local network)
#   - 127.0.0.1 = Localhost only (local machine access only)
NATS_HOST=0.0.0.0
NATS_PORT=4222
NATS_DATA_DIR=./data/overwatch

# NATS Security
# Enable authentication by setting NATS_ENABLE_AUTH=true
# If enabled, you must provide a token
NATS_ENABLE_AUTH=true
NATS_AUTH_TOKEN=reindustrialize-america

# WebSocket/CORS Allowed Origins (comma-separated)
# Use "*" to allow all origins (development only)
# Example: http://localhost:8080,http://255.255.255.255:8080
ALLOWED_ORIGINS=*

# Security Notes:
# For local development: Use 0.0.0.0 to allow access from other devices on your network
# For localhost-only: Change HOST and NATS_HOST to 127.0.0.1
# For production: Enable TLS, use strong tokens, and configure firewall rules
