# =============================================================================
# Constellation Overwatch - Configuration
# =============================================================================
# Copy this file to .env and customize as needed.
# Most defaults work out of the box - uncomment only what you want to change.
# =============================================================================

# -----------------------------------------------------------------------------
# Authentication (REQUIRED)
# -----------------------------------------------------------------------------
# Unified token for REST API and NATS authentication. CHANGE THIS IN PRODUCTION!
# - REST API: Authorization: Bearer <OVERWATCH_TOKEN>
# - NATS: nats://localhost:4222 -token <OVERWATCH_TOKEN>
OVERWATCH_TOKEN=reindustrialize-dev-token

# -----------------------------------------------------------------------------
# Network Configuration (Optional - defaults shown)
# -----------------------------------------------------------------------------
# HOST: Bind address (0.0.0.0 = all interfaces, 127.0.0.1 = localhost only)
# PORT: Web UI and REST API port
# HOST=0.0.0.0
# PORT=8080

# -----------------------------------------------------------------------------
# Storage (Optional - defaults shown)
# -----------------------------------------------------------------------------
# Root data directory. DB stored at <dir>/db/constellation.db,
# NATS JetStream at <dir>/overwatch/
# OVERWATCH_DATA_DIR=./data

# -----------------------------------------------------------------------------
# NATS Configuration (Optional - defaults shown)
# -----------------------------------------------------------------------------
# NATS_HOST: NATS bind address (0.0.0.0 = all interfaces)
# NATS_PORT: Port for edge device connections
# NATS_HOST=0.0.0.0
# NATS_PORT=4222

# -----------------------------------------------------------------------------
# CORS (Optional - defaults shown)
# -----------------------------------------------------------------------------
# Allowed origins for WebSocket connections (comma-separated, or * for all)
# ALLOWED_ORIGINS=*

# -----------------------------------------------------------------------------
# MediaMTX Video Integration (Optional)
# -----------------------------------------------------------------------------
# URL for MediaMTX REST API. Enables LIVE/OFFLINE stream status and viewer counts.
# Leave empty/unset to disable MediaMTX integration (video page shows no streams).
# MEDIAMTX_API_URL=http://localhost:9997

# Base URL for MediaMTX WebRTC (WHEP) endpoint.
# Used to build WHEP URLs for browser video playback.
# MEDIAMTX_WEBRTC_URL=http://localhost:8889

# -----------------------------------------------------------------------------
# Admin Bootstrap (First Run)
# -----------------------------------------------------------------------------
# On first run, an admin user is created with this email.
# The login URL is printed to the console — visit it to register a passkey.
# OVERWATCH_ADMIN_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# WebAuthn / Passkey Configuration
# -----------------------------------------------------------------------------
# Relying Party ID (your domain). Use "localhost" for development.
# OVERWATCH_RPID=localhost
# Base URL for generating invite links
# OVERWATCH_BASE_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Set to "true" to allow insecure cookies (HTTP dev without TLS)
# OVERWATCH_INSECURE=true

# =============================================================================
# Quick Start
# =============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Run: ./overwatch (or: go run ./cmd/microlith/main.go)
# 3. Open: http://localhost:8080
# 4. API calls need: Authorization: Bearer <OVERWATCH_TOKEN>
# 5. Edge devices connect: nats://localhost:4222 with token <OVERWATCH_TOKEN>
#
# PRODUCTION CHECKLIST:
# [ ] Change OVERWATCH_TOKEN to a secure random string
# [ ] Set OVERWATCH_RPID and OVERWATCH_BASE_URL for passkey auth
# [ ] Consider HOST=127.0.0.1 behind a reverse proxy with TLS
# =============================================================================
