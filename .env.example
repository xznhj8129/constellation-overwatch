# Constellation Overwatch
# Copy to .env — runs with zero config: cp .env.example .env
# All values below are defaults. Uncomment only what you need to change.

# --- Dev defaults (everything works out of the box) ---
# PORT=8080
# NATS_PORT=4222
# NATS_HOST=127.0.0.1        # Set to 0.0.0.0 for edge device NATS access
# OVERWATCH_DATA_DIR=./data
ALLOWED_ORIGINS=http://localhost:8080

# --- NATS TLS (for edge device connections) ---
# NATS_ENABLE_TLS=true
# NATS_TLS_CERT=/path/to/nats.crt
# NATS_TLS_KEY=/path/to/nats.key

# --- Video (optional, disabled by default) ---
# MEDIAMTX_API_URL=http://localhost:9997
# MEDIAMTX_WEBRTC_URL=http://localhost:8889

# --- Production overrides ---
# OVERWATCH_RPID=yourdomain.com
# OVERWATCH_BASE_URL=https://yourdomain.com
# OVERWATCH_ADMIN_EMAIL=admin@yourdomain.com
# OVERWATCH_KEY_HASH_SECRET=  # Set to enable HMAC-SHA256 API key hashing
# HOST=127.0.0.1
