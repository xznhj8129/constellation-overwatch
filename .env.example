# =============================================================================
# Constellation Overwatch - Configuration
# =============================================================================
# Copy this file to .env and customize as needed.
# Most defaults work out of the box - uncomment only what you want to change.
# =============================================================================

# -----------------------------------------------------------------------------
# API Authentication (REQUIRED)
# -----------------------------------------------------------------------------
# Bearer token for REST API access. CHANGE THIS IN PRODUCTION!
API_BEARER_TOKEN=constellation-dev-token

# -----------------------------------------------------------------------------
# NATS Authentication (ENABLED BY DEFAULT)
# -----------------------------------------------------------------------------
# Token authentication for edge devices connecting via NATS.
# Edge devices must connect with: nats://localhost:4222 -token <NATS_AUTH_TOKEN>
NATS_ENABLE_AUTH=true
NATS_AUTH_TOKEN=reindustrialize-america

# -----------------------------------------------------------------------------
# Network Configuration (Optional - defaults shown)
# -----------------------------------------------------------------------------
# HOST: Bind address (0.0.0.0 = all interfaces, 127.0.0.1 = localhost only)
# PORT: Web UI and REST API port
# HOST=0.0.0.0
# PORT=8080

# -----------------------------------------------------------------------------
# NATS Configuration (Optional - defaults shown)
# -----------------------------------------------------------------------------
# NATS_HOST: NATS bind address (0.0.0.0 = all interfaces)
# NATS_PORT: Port for edge device connections
# NATS_DATA_DIR: JetStream persistence directory
# NATS_HOST=0.0.0.0
# NATS_PORT=4222
# NATS_DATA_DIR=./data/overwatch

# -----------------------------------------------------------------------------
# Database (Optional - defaults shown)
# -----------------------------------------------------------------------------
# Path to SQLite database (auto-created if missing)
# DB_PATH=./data/db/constellation.db

# -----------------------------------------------------------------------------
# CORS (Optional - defaults shown)
# -----------------------------------------------------------------------------
# Allowed origins for WebSocket connections (comma-separated, or * for all)
# ALLOWED_ORIGINS=*

# -----------------------------------------------------------------------------
# Web UI Authentication (Optional)
# -----------------------------------------------------------------------------
# Set a password to require login for the Web UI dashboard
# Leave empty/unset to allow unauthenticated access
# WEB_UI_PASSWORD=

# =============================================================================
# Quick Start
# =============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Run: ./overwatch (or: go run ./cmd/microlith/main.go)
# 3. Open: http://localhost:8080
# 4. API calls need: Authorization: Bearer constellation-dev-token
# 5. Edge devices connect: nats://localhost:4222 with token reindustrialize-america
#
# PRODUCTION CHECKLIST:
# [ ] Change API_BEARER_TOKEN to a secure random string
# [ ] Change NATS_AUTH_TOKEN to a secure random string
# [ ] Set WEB_UI_PASSWORD for dashboard protection
# [ ] Consider HOST=127.0.0.1 behind a reverse proxy with TLS
# =============================================================================
